{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "focaro",
  "version": "0.1.0",
  "identifier": "com.focaro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "dropdown",
        "title": "focaro",
        "width": 320,
        "height": 540,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      },
      {
        "label": "dashboard",
        "title": "",
        "width": 900,
        "height": 650,
        "visible": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "save-reference",
        "title": "",
        "width": 480,
        "height": 280,
        "visible": false,
        "resizable": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "settings",
        "title": "",
        "width": 600,
        "height": 500,
        "visible": false,
        "resizable": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "onboarding",
        "title": "",
        "width": 520,
        "height": 460,
        "visible": false,
        "resizable": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
